{
  "manifest_version": 3,
  "name": "Send to ntfy",
  "version": "2.4.1",
  "description": "Send notifications to ntfy.sh with file attachments, priority, and tags",
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "scripting",
    "notifications"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{8d2be1ac-e096-47ce-87de-8a9fee099bf1}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}